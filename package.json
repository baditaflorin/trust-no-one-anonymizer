{
  "name": "trust-no-one-anonymizer",
  "version": "0.1.0",
  "description": "Client-side face and voice anonymizer for private browser-based video calls.",
  "type": "module",
  "private": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/baditaflorin/trust-no-one-anonymizer.git"
  },
  "homepage": "https://baditaflorin.github.io/trust-no-one-anonymizer/",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "node scripts/prebuild.mjs && vite build && node scripts/postbuild.mjs",
    "preview": "vite preview --host 0.0.0.0",
    "pages-preview": "vite preview --host 127.0.0.1 --port 4287 --strictPort --outDir docs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "fmt": "prettier --write .",
    "fmt:check": "prettier --check .",
    "smoke": "playwright test --config playwright.config.ts"
  },
  "dependencies": {
    "@jitsi/rnnoise-wasm": "^0.2.1",
    "@mediapipe/tasks-vision": "^0.10.35",
    "@tensorflow/tfjs": "~4.11.0",
    "@upscalerjs/esrgan-slim": "^1.0.0",
    "lucide": "^0.468.0",
    "upscaler": "^1.0.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.57.0",
    "@types/node": "^24.10.1",
    "@vitest/coverage-v8": "^4.0.8",
    "autoprefixer": "^10.4.22",
    "eslint": "^9.39.1",
    "globals": "^15.15.0",
    "http-server": "^14.1.1",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "tailwindcss": "^3.4.18",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vitest": "^4.0.8"
  }
}
